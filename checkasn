# ───────────────────────────────────────────────────────────
#  КОНСТАНТЫ
# ───────────────────────────────────────────────────────────
CACHE_DIR = Path("/var/cache/xray-asn-stats")
BGP_TABLE_URL = "https://bgp.tools/table.txt"
BGP_ASNAMES_URL = "https://bgp.tools/asns.csv"
TABLE_TTL_HOURS = 24
USER_AGENT = "checkasn/1.1 Snow-VPN (t.me/SnowfallVPN_bot)"

BANNED_ASNS_FILE = "/opt/asn-block/asns.conf"

DEFAULT_LOG_CANDIDATES = [
    "/var/log/remnanode/access.log",
    "/var/log/xray/access.log",
    "/opt/remnanode/access.log",
    "/usr/local/etc/xray/access.log",
]

# Xray access.log:
#   2024/06/15 12:34:56 from 1.2.3.4:50612 accepted //tcp:api.telegram.org:443 [inbound -> direct] email: 177979
LOG_RE = re.compile(
    r'^(?P<ts>\d{4}/\d{2}/\d{2}\s\d{2}:\d{2}:\d{2})'
    r'.*?(?:from\s+)?'
    r'(?P<ip>\d{1,3}(?:\.\d{1,3}){3}):\d+\s+accepted\s+'
    r'\S+'
    r'(?:.*?email:\s*(?P<email>\S+))?'
)

GREEN  = '\033[0;32m'
CYAN   = '\033[0;36m'
YELLOW = '\033[1;33m'
RED    = '\033[0;31m'
BOLD   = '\033[1m'
DIM    = '\033[2m'
NC     = '\033[0m'

def info(msg):  print(f"{CYAN}[--]{NC} {msg}")
def log(msg):   print(f"{GREEN}[OK]{NC} {msg}")
def warn(msg):  print(f"{YELLOW}[!!]{NC} {msg}")
def err(msg):
    print(f"{RED}[ERR]{NC} {msg}", file=sys.stderr)
    sys.exit(1)

# ───────────────────────────────────────────────────────────
#  КЭШИРОВАНИЕ
# ───────────────────────────────────────────────────────────
def download(url, dst):
    req = urllib.request.Request(url, headers={"User-Agent": USER_AGENT})
    with urllib.request.urlopen(req, timeout=60) as resp:
        with open(dst, 'wb') as f:
            while True:
                chunk = resp.read(65536)
                if not chunk:
                    break
                f.write(chunk)

def ensure_cached(url, filename, force=False):
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    path = CACHE_DIR / filename
    needs_dl = force or not path.exists()
    if not needs_dl:
        age_h = (time.time() - path.stat().st_mtime) / 3600
        if age_h > TABLE_TTL_HOURS:
            info(f"  {filename}: кэш устарел ({age_h:.1f}ч), обновляю")
            needs_dl = True
    if needs_dl:
        info(f"  скачиваю {url}")
        try:
            download(url, path)
            log(f"  сохранил {path}")
        except Exception as e:
            if path.exists():
                warn(f"  ошибка скачивания: {e}, использую старый кэш")
            else:
                err(f"  не удалось скачать {url}: {e}")
    return path

# ───────────────────────────────────────────────────────────
#  BGP LOOKUP
# ───────────────────────────────────────────────────────────
def build_lookup(table_path):
    by_mask = defaultdict(dict)
    with open(table_path, 'r', encoding='utf-8', errors='ignore') as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith('#'):
                continue
            parts = line.split()
            if len(parts) < 2:
                continue
            prefix_str, asn_str = parts[0], parts[1]
            if ':' in prefix_str or '/' not in prefix_str:
                continue
            try:
                net = ipaddress.IPv4Network(prefix_str, strict=False)
                by_mask[net.prefixlen][int(net.network_address)] = f"AS{asn_str}"
            except (ValueError, ipaddress.AddressValueError):
                continue
    return dict(by_mask)

def lookup_asn(ip_str, by_mask):
    try:
        ip_int = int(ipaddress.IPv4Address(ip_str))
    except (ValueError, ipaddress.AddressValueError):
        return None
    for mask_len in range(32, 7, -1):
        mask_dict = by_mask.get(mask_len)
        if not mask_dict:
            continue
        mask = (0xFFFFFFFF << (32 - mask_len)) & 0xFFFFFFFF
        network_int = ip_int & mask
        if network_int in mask_dict:
            return mask_dict[network_int]
    return None

def load_asn_names(path):
    names = {}
    with open(path, 'r', encoding='utf-8', errors='ignore') as f:
        for i, line in enumerate(f):
            if i == 0:
                continue
            line = line.strip()
            if not line:
                continue
            m = re.match(r'^"?(\d+)"?\s*,\s*"([^"]*)"', line)
            if not m:
                continue
            asn_num, name = m.group(1), m.group(2)
            names[f"AS{asn_num}"] = name
    return names

def load_banned():
    p = Path(BANNED_ASNS_FILE)
    if not p.exists():
        return set()
    banned = set()
    with open(p) as f:
        for line in f:
            line = line.strip().upper()
            if line.startswith('AS') and line[2:].isdigit():
                banned.add(line)
    return banned

# ───────────────────────────────────────────────────────────
#  ПАРСИНГ ЛОГА
# ───────────────────────────────────────────────────────────
def find_log_paths(log_path):
    main = Path(log_path)
    if not main.exists():
        return []
    paths = [main]
    log_dir = main.parent
    base = main.name
    for p in sorted(log_dir.glob(f"{base}.*")):
        if p.is_file():
            paths.append(p)
    return paths

def parse_log(log_path, hours):
    cutoff = datetime.now() - timedelta(hours=hours)
    paths = find_log_paths(log_path)
    if not paths:
        err(f"Лог не найден: {log_path}")

    info(f"  файлов лога: {len(paths)}")
    total_lines = 0
    matched = 0
    for path in paths:
        opener = gzip.open if str(path).endswith('.gz') else open
        try:
            with opener(path, 'rt', encoding='utf-8', errors='ignore') as f:
                for line in f:
                    total_lines += 1
                    m = LOG_RE.search(line)
                    if not m:
                        continue
                    try:
                        ts = datetime.strptime(m.group('ts'), '%Y/%m/%d %H:%M:%S')
                    except ValueError:
                        continue
                    if ts < cutoff:
                        continue
                    matched += 1
                    yield m.group('ip'), m.group('email')
        except OSError as e:
            warn(f"  не смог открыть {path}: {e}")
            continue

    info(f"  прочитано строк: {total_lines}, в окне: {matched}")

# ───────────────────────────────────────────────────────────
#  АГРЕГАЦИЯ
# ───────────────────────────────────────────────────────────
def aggregate(events, lookup_fn):
    asn_conns = Counter()
    asn_unique_ips = defaultdict(set)
    asn_emails = defaultdict(Counter)
    asn_email_ips = defaultdict(lambda: defaultdict(set))
    email_asns = defaultdict(set)
    email_conns = Counter()
    total = 0

    for ip, email in events:
        total += 1
        asn = lookup_fn(ip) or "UNKNOWN"
        asn_conns[asn] += 1
        asn_unique_ips[asn].add(ip)
        if email:
            asn_emails[asn][email] += 1
            asn_email_ips[asn][email].add(ip)
            email_asns[email].add(asn)
            email_conns[email] += 1

    return {
        'total': total,
        'asn_conns': asn_conns,
        'asn_unique_ips': asn_unique_ips,
        'asn_emails': asn_emails,
        'asn_email_ips': asn_email_ips,
        'email_asns': email_asns,
        'email_conns': email_conns,
    }

# ───────────────────────────────────────────────────────────
#  ВЫВОД: общий топ ASN
# ───────────────────────────────────────────────────────────
def print_asn_table(stats, asn_names, banned_asns, top_n, only_unbanned, banned_only, hours):
    rows = []
    for asn, conns in stats['asn_conns'].items():
        unique = len(stats['asn_unique_ips'][asn])
        name = asn_names.get(asn, '?')
        is_banned = asn in banned_asns
        if only_unbanned and is_banned:
            continue
        if banned_only and not is_banned:
            continue
        rows.append((asn, name, conns, unique, is_banned))

    rows.sort(key=lambda r: r[2], reverse=True)
    rows = rows[:top_n]

    if not rows:
        if banned_only:
            log("Подключений из забаненных ASN не обнаружено — firewall работает чисто 🎯")
        else:
            warn("Нечего показывать")
        return

    if banned_only:
        title = f"Подключения из ЗАБАНЕННЫХ ASN (последние {hours}ч)"
    elif only_unbanned:
        title = f"Топ ASN — только НЕ в бане (последние {hours}ч)"
    else:
        title = f"Топ ASN по подключениям (последние {hours}ч)"

    print(f"\n{CYAN}{BOLD}═══ {title} ═══{NC}")

    if banned_only:
        print(f"{DIM}Эти подключения прошли мимо asn-block firewall.{NC}")
        print(f"{DIM}Возможные причины: префикс отсутствует в bgp.tools таблице,{NC}")
        print(f"{DIM}отставание обновления ipset, или firewall ещё не применён.{NC}")
    print()

    name_w = 28
    print(f"{'ASN':<11} {'Имя':<{name_w}} {'Подкл':>8} {'Уник.IP':>9} {'Эмейлов':>9} {'Бан':>5}")
    print("─" * (11 + 1 + name_w + 1 + 8 + 1 + 9 + 1 + 9 + 1 + 5))

    for asn, name, conns, unique, banned in rows:
        nm = (name[:name_w-1] + '…') if len(name) > name_w else name
        n_emails = len(stats['asn_emails'].get(asn, {}))
        flag = f'{RED}✓{NC}' if banned else ''
        suspicious = (not banned) and conns > 100 and unique > 0 and (conns / unique) > 20

        if banned:
            asn_str = f"{RED}{asn}{NC}"
        elif suspicious:
            asn_str = f"{YELLOW}{asn}{NC}"
        else:
            asn_str = asn

        pad = ' ' * (11 - len(asn))
        print(f"{asn_str}{pad}{nm:<{name_w}} {conns:>8} {unique:>9} {n_emails:>9} {flag:>5}")

        # Под забаненными ASN — топ-3 email-а
        if banned and n_emails > 0:
            top_emails = stats['asn_emails'][asn].most_common(3)
            for i, (email, ecount) in enumerate(top_emails):
                ips_count = len(stats['asn_email_ips'][asn][email])
                is_last_shown = (i == len(top_emails) - 1)
                more = n_emails > 3
                prefix = '  ├─' if (not is_last_shown or more) else '  └─'
                em_show = email[:30] + ('…' if len(email) > 30 else '')
                print(f"{DIM}{prefix} {em_show:<32} {ecount:>4} подкл, {ips_count} IP{NC}")
            if n_emails > 3:
                print(f"{DIM}  └─ … +{n_emails - 3} ещё email'ов{NC}")
            print()

    print()
    print(f"{DIM}Всего событий обработано: {stats['total']}{NC}")
    print(f"{DIM}Уникальных ASN:           {len(stats['asn_conns'])}{NC}")
    if not banned_only:
        print(f"{DIM}{RED}Красный{NC}{DIM} — ASN в банлисте (трафик прошёл!).{NC}")
        print(f"{DIM}{YELLOW}Жёлтый{NC}{DIM} — подозрительный conn/uniqIP > 20.{NC}")
    print()

# ───────────────────────────────────────────────────────────
#  ВЫВОД: email c подключениями из забаненных ASN
# ───────────────────────────────────────────────────────────
def print_emails_using_banned(stats, banned_asns, top_n=25):
    suspects = []
    for email, asns in stats['email_asns'].items():
        banned_in = asns & banned_asns
        if not banned_in:
            continue
        total = stats['email_conns'][email]
        banned_count = sum(
            stats['asn_emails'][asn].get(email, 0) for asn in banned_in
        )
        legit_asns = asns - banned_asns
        suspects.append((email, total, banned_count, banned_in, legit_asns))

    if not suspects:
        return

    suspects.sort(key=lambda x: x[2], reverse=True)
    suspects = suspects[:top_n]

    print(f"\n{CYAN}{BOLD}═══ Email с подключениями из ЗАБАНЕННЫХ ASN ═══{NC}")
    print(f"{DIM}(вероятная цепочка VPN: пользователь → VPS → Snow VPN){NC}\n")

    print(f"{'Email':<32} {'Всего':>6} {'Бан.подкл':>11}  ASN-разбивка")
    print("─" * 110)

    for email, total, banned_count, banned_in, legit in suspects:
        pct = (banned_count * 100 / total) if total else 0
        em = (email[:30] + '…') if len(email) > 31 else email
        banned_str = ", ".join(sorted(banned_in))

        # формируем строку: красным баны, обычным легит
        asn_info_parts = [f"{RED}{banned_str}{NC}"]
        if legit:
            legit_sorted = sorted(legit)
            legit_show = ", ".join(legit_sorted[:3])
            if len(legit) > 3:
                legit_show += f" +{len(legit)-3}"
            asn_info_parts.append(f"{DIM}| легит: {legit_show}{NC}")
        asn_info = "  ".join(asn_info_parts)

        pct_str = f"({pct:>3.0f}%)"
        print(f"{em:<32} {total:>6} {banned_count:>5} {pct_str:>5}  {asn_info}")

    print()
    print(f"{DIM}«Бан.подкл» — сколько подключений конкретного email пришло{NC}")
    print(f"{DIM}с IP в забаненных ASN. 100% — пользователь ходит ТОЛЬКО через VPS,{NC}")
    print(f"{DIM}явная цепочка прокси. Низкий % + легитимный ASN — возможен шаринг{NC}")
    print(f"{DIM}ключа между обычным юзером и кем-то на VPS.{NC}\n")

# ───────────────────────────────────────────────────────────
#  ВЫВОД: шаринг (email с подключениями с многих ASN)
# ───────────────────────────────────────────────────────────
def print_sharing(stats, threshold=3, top_n=15):
    suspects = [
        (email, asns) for email, asns in stats['email_asns'].items()
        if len(asns) >= threshold
    ]
    if not suspects:
        info("Шаринг ключей не обнаружен")
        return
    suspects.sort(key=lambda x: len(x[1]), reverse=True)

    print(f"\n{CYAN}{BOLD}═══ Подозрительный шаринг ключей ═══{NC}")
    print(f"{DIM}(email подключается с {threshold}+ разных ASN){NC}\n")

    print(f"{'Email':<32} {'ASN':>5}  Список ASN")
    print("─" * 90)
    for email, asns in suspects[:top_n]:
        em = email[:31]
        asn_sorted = sorted(asns)
        shown = asn_sorted[:5]
        rest = len(asns) - len(shown)
        asn_list = ", ".join(shown)
        if rest > 0:
            asn_list += f" {DIM}+{rest}{NC}"
        print(f"{em:<32} {len(asns):>5}  {asn_list}")
    print()

# ───────────────────────────────────────────────────────────
#  MAIN
# ───────────────────────────────────────────────────────────
def detect_log_path():
    for c in DEFAULT_LOG_CANDIDATES:
        if Path(c).exists():
            return c
    return DEFAULT_LOG_CANDIDATES[0]

def main():
    ap = argparse.ArgumentParser(
        description="Анализ Xray access.log по ASN",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    ap.add_argument('--log', help='Путь к access.log (по умолчанию — автодетект)')
    ap.add_argument('--hours', type=float, default=24,
                    help='Сколько часов назад смотреть (default: 24)')
    ap.add_argument('--top', type=int, default=20,
                    help='Сколько ASN показать (default: 20)')

    mode = ap.add_mutually_exclusive_group()
    mode.add_argument('--only-unbanned', action='store_true',
                      help='Показать ТОЛЬКО ASN которых НЕТ в бане (кандидаты)')
    mode.add_argument('--banned-only', action='store_true',
                      help='Показать ТОЛЬКО подключения из ЗАБАНЕННЫХ ASN + emails')

    ap.add_argument('--emails', action='store_true',
                    help='+ детектор шаринга и emails-с-забаненных-ASN')
    ap.add_argument('--no-cache', action='store_true',
                    help='Принудительно перекачать BGP таблицу')
    args = ap.parse_args()

    print(f"{CYAN}{BOLD}")
    print("╔═══════════════════════════════════════════════╗")
    print("║       checkasn — Snow VPN access analyzer     ║")
    print("╚═══════════════════════════════════════════════╝")
    print(f"{NC}")

    log_path = args.log or detect_log_path()

    info("Загружаю BGP таблицу...")
    table_path = ensure_cached(BGP_TABLE_URL, "table.txt", force=args.no_cache)
    names_path = ensure_cached(BGP_ASNAMES_URL, "asns.csv", force=args.no_cache)

    info("Строю lookup-индекс...")
    by_mask = build_lookup(table_path)
    total_prefixes = sum(len(d) for d in by_mask.values())
    log(f"  префиксов: {total_prefixes}")

    info("Загружаю имена ASN...")
    asn_names = load_asn_names(names_path)
    log(f"  имён: {len(asn_names)}")

    banned = load_banned()
    info(f"В бане (asn-block): {len(banned)} ASN")

    info(f"Парсю access.log: {log_path}")
    events = parse_log(log_path, args.hours)
    stats = aggregate(events, lambda ip: lookup_asn(ip, by_mask))

    if stats['total'] == 0:
        warn("Нет событий в указанном временном окне")
        return

    print_asn_table(
        stats, asn_names, banned, args.top,
        args.only_unbanned, args.banned_only, args.hours,
    )

    # В режиме --banned-only автоматом показываем разбивку по email-ам
    # (если есть подключения — то есть рядом с таблицей уже виден per-ASN top-3)
    # Дополнительно — общий список email с любыми банами:
    if args.banned_only or args.emails:
        print_emails_using_banned(stats, banned)

    if args.emails:
        print_sharing(stats)

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nПрервано")
        sys.exit(130)
