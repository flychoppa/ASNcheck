#  MAIN
# ───────────────────────────────────────────────────────────
def detect_log_path():
    for c in DEFAULT_LOG_CANDIDATES:
        if Path(c).exists():
            return c
    return DEFAULT_LOG_CANDIDATES[0]

def main():
    ap = argparse.ArgumentParser(
        description="Детектор нарушителей по хостинговым ASN (Snow VPN)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    ap.add_argument('--log', help='Путь к access.log (по умолчанию автодетект)')
    ap.add_argument('--hours', type=float, default=24,
                    help='Окно анализа в часах (default: 24)')
    ap.add_argument('--severity', choices=['all', 'high', 'med', 'low'],
                    default='all', help='Фильтр по уровню (default: all)')
    ap.add_argument('--min-hosting', type=int, default=5,
                    help='Мин. хостинг-подкл чтобы пометить (default: 5)')
    ap.add_argument('--no-cache', action='store_true',
                    help='Принудительно перекачать BGP таблицу')
    args = ap.parse_args()

    print(f"{CYAN}{BOLD}")
    print("╔═══════════════════════════════════════════════╗")
    print("║   checkasn — Snow VPN abuse / chain detector  ║")
    print("╚═══════════════════════════════════════════════╝")
    print(f"{NC}")

    log_path = args.log or detect_log_path()

    info("Загружаю BGP таблицу...")
    table_path = ensure_cached(BGP_TABLE_URL, "table.txt", force=args.no_cache)
    names_path = ensure_cached(BGP_ASNAMES_URL, "asns.csv", force=args.no_cache)

    info("Строю lookup-индекс...")
    by_mask = build_lookup(table_path)
    total_prefixes = sum(len(d) for d in by_mask.values())
    log(f"  префиксов: {total_prefixes}")

    info("Загружаю имена ASN...")
    asn_names = load_asn_names(names_path)
    log(f"  имён: {len(asn_names)}")

    info("Собираю список хостинговых ASN...")
    hosting, sources = load_hosting_asns()
    for asn in list(hosting.keys()):
        if not hosting[asn]:
            hosting[asn] = asn_names.get(asn, '?')
    hosting_set = set(hosting.keys())
    log(f"  хостингов: {len(hosting_set)} (источники: {', '.join(sources)})")

    info(f"Парсю access.log: {log_path}")
    events = parse_log(log_path, args.hours)
    per_email, grand_total, grand_hosting = aggregate(
        events,
        lambda ip: lookup_asn(ip, by_mask),
        hosting_set,
    )

    if grand_total == 0:
        warn("Нет событий в указанном окне (проверь --hours и путь к логу)")
        return

    for asn, name in hosting.items():
        if name and asn not in asn_names:
            asn_names[asn] = name

    print_violators(
        per_email, grand_total, grand_hosting, asn_names,
        args.min_hosting, args.severity, args.hours,
    )

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nПрервано")
        sys.exit(130)
