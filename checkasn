# ───────────────────────────────────────────────────────────
#  КЭШИРОВАНИЕ BGP
# ───────────────────────────────────────────────────────────
def download(url, dst):
    req = urllib.request.Request(url, headers={"User-Agent": USER_AGENT})
    with urllib.request.urlopen(req, timeout=60) as resp:
        with open(dst, 'wb') as f:
            while True:
                chunk = resp.read(65536)
                if not chunk:
                    break
                f.write(chunk)

def ensure_cached(url, filename, force=False):
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    path = CACHE_DIR / filename
    needs_dl = force or not path.exists()
    if not needs_dl:
        age_h = (time.time() - path.stat().st_mtime) / 3600
        if age_h > TABLE_TTL_HOURS:
            info(f"  {filename}: кэш устарел ({age_h:.1f}ч), обновляю")
            needs_dl = True
    if needs_dl:
        info(f"  скачиваю {url}")
        try:
            download(url, path)
            log(f"  сохранил {path}")
        except Exception as e:
            if path.exists():
                warn(f"  ошибка скачивания: {e}, использую старый кэш")
            else:
                err(f"  не удалось скачать {url}: {e}")
    return path

# ───────────────────────────────────────────────────────────
#  IP → ASN
# ───────────────────────────────────────────────────────────
def build_lookup(table_path):
    by_mask = defaultdict(dict)
    with open(table_path, 'r', encoding='utf-8', errors='ignore') as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith('#'):
                continue
            parts = line.split()
            if len(parts) < 2:
                continue
            prefix_str, asn_str = parts[0], parts[1]
            if ':' in prefix_str or '/' not in prefix_str:
                continue
            try:
                net = ipaddress.IPv4Network(prefix_str, strict=False)
                by_mask[net.prefixlen][int(net.network_address)] = f"AS{asn_str}"
            except (ValueError, ipaddress.AddressValueError):
                continue
    return dict(by_mask)

def lookup_asn(ip_str, by_mask):
    try:
        ip_int = int(ipaddress.IPv4Address(ip_str))
    except (ValueError, ipaddress.AddressValueError):
        return None
    for mask_len in range(32, 7, -1):
        mask_dict = by_mask.get(mask_len)
        if not mask_dict:
            continue
        mask = (0xFFFFFFFF << (32 - mask_len)) & 0xFFFFFFFF
        network_int = ip_int & mask
        if network_int in mask_dict:
            return mask_dict[network_int]
    return None

def load_asn_names(path):
    names = {}
    with open(path, 'r', encoding='utf-8', errors='ignore') as f:
        for i, line in enumerate(f):
            if i == 0:
                continue
            line = line.strip()
            if not line:
                continue
            m = re.match(r'^"?(\d+)"?\s*,\s*"([^"]*)"', line)
            if not m:
                continue
            names[f"AS{m.group(1)}"] = m.group(2)
    return names

# ───────────────────────────────────────────────────────────
#  СПИСОК ХОСТИНГОВЫХ ASN
# ───────────────────────────────────────────────────────────
def load_hosting_asns():
    hosting = dict(DEFAULT_HOSTING_ASNS)
    sources = ["built-in"]

    p = Path(ASN_BLOCK_CONF)
    if p.exists():
        n_added = 0
        with open(p) as f:
            for line in f:
                line = line.strip().upper()
                if line.startswith('AS') and line[2:].isdigit():
                    if line not in hosting:
                        hosting[line] = ""
                        n_added += 1
        if n_added > 0:
            sources.append(f"asn-block (+{n_added})")

    p = Path(HOSTING_EXTRA_FILE)
    if p.exists():
        n_added = 0
        with open(p) as f:
            for line in f:
                line = line.strip().upper().split('#')[0].strip()
                if line.startswith('AS') and line[2:].isdigit():
                    if line not in hosting:
                        hosting[line] = ""
                        n_added += 1
        if n_added > 0:
            sources.append(f"hosting-extra (+{n_added})")

    return hosting, sources

# ───────────────────────────────────────────────────────────
#  ПАРСИНГ XRAY ЛОГА
# ───────────────────────────────────────────────────────────
def find_log_paths(log_path):
    main = Path(log_path)
    if not main.exists():
        return []
    paths = [main]
    log_dir = main.parent
    base = main.name
    for p in sorted(log_dir.glob(f"{base}.*")):
        if p.is_file():
            paths.append(p)
    return paths

def parse_log(log_path, hours):
    cutoff = datetime.now() - timedelta(hours=hours)
    paths = find_log_paths(log_path)
    if not paths:
        err(f"Лог не найден: {log_path}")

    # === Оптимизация #3: пропуск .gz ротированных файлов с mtime < cutoff ===
    # У ротированных .gz файл создаётся в момент ротации, и всё содержимое
    # внутри старше mtime. Значит если mtime < cutoff — внутри ничего не нужно.
    paths_to_process = []
    skipped_gz = 0
    for p in paths:
        if str(p).endswith('.gz'):
            try:
                mtime = datetime.fromtimestamp(p.stat().st_mtime)
                if mtime < cutoff:
                    skipped_gz += 1
                    info(f"  пропускаю {p.name} "
                         f"(rotated {mtime:%Y-%m-%d %H:%M}, всё старше cutoff)")
                    continue
            except OSError:
                pass
        paths_to_process.append(p)

    if skipped_gz > 0:
        info(f"  пропущено .gz файлов по mtime: {skipped_gz}")
    info(f"  файлов к обработке: {len(paths_to_process)}")

    # === Оптимизация #5: прогресс-индикатор ===
    total_lines = 0
    matched = 0
    start = time.time()

    for path in paths_to_process:
        opener = gzip.open if str(path).endswith('.gz') else open
        try:
            with opener(path, 'rt', encoding='utf-8', errors='ignore') as f:
                for line in f:
                    total_lines += 1

                    if total_lines % PROGRESS_EVERY == 0:
                        elapsed = time.time() - start
                        rate = total_lines / elapsed if elapsed > 0 else 0
                        info(f"  {total_lines/1e6:.0f}M строк за {elapsed:.0f}с "
                             f"({rate/1e6:.2f}M/сек), найдено: {matched}")

                    m = LOG_RE.search(line)
                    if not m:
                        continue
                    try:
                        ts = datetime.strptime(m.group('ts'), '%Y/%m/%d %H:%M:%S')
                    except ValueError:
                        continue
                    if ts < cutoff:
                        continue
                    matched += 1
                    yield m.group('ip'), m.group('email')
        except OSError as e:
            warn(f"  не смог открыть {path}: {e}")
            continue

    elapsed = time.time() - start
    rate = total_lines / elapsed if elapsed > 0 else 0
    info(f"  готово: {total_lines} строк за {elapsed:.1f}с "
         f"({rate/1e6:.2f}M/сек), событий в окне: {matched}")

# ───────────────────────────────────────────────────────────
#  АГРЕГАЦИЯ ПО EMAIL
# ───────────────────────────────────────────────────────────
def aggregate(events, lookup_fn, hosting_asns_set):
    per_email = defaultdict(lambda: {
        'total': 0,
        'hosting_total': 0,
        'unique_ips': set(),
        'hosting_ips': set(),
        'hosting_breakdown': defaultdict(lambda: {'count': 0, 'ips': set()}),
        'legit_breakdown': Counter(),
    })
    grand_total = 0
    grand_hosting = 0

    for ip, email in events:
        grand_total += 1
        if not email:
            continue
        asn = lookup_fn(ip) or "UNKNOWN"
        d = per_email[email]
        d['total'] += 1
        d['unique_ips'].add(ip)
        if asn in hosting_asns_set:
            grand_hosting += 1
            d['hosting_total'] += 1
            d['hosting_ips'].add(ip)
            d['hosting_breakdown'][asn]['count'] += 1
            d['hosting_breakdown'][asn]['ips'].add(ip)
        else:
            d['legit_breakdown'][asn] += 1

    return per_email, grand_total, grand_hosting

# ───────────────────────────────────────────────────────────
#  КЛАССИФИКАЦИЯ
# ───────────────────────────────────────────────────────────
def classify(d, min_hosting):
    h = d['hosting_total']
    t = d['total']
    if h < min_hosting:
        return None
    pct = (h * 100 / t) if t else 0
    if pct >= 90:
        return 'HIGH'
    if pct >= 30:
        return 'MED'
    return 'LOW'

SEVERITY_COLOR = {'HIGH': RED, 'MED': YELLOW, 'LOW': CYAN}
SEVERITY_ORDER = {'HIGH': 0, 'MED': 1, 'LOW': 2}

# ───────────────────────────────────────────────────────────
#  ВЫВОД
# ───────────────────────────────────────────────────────────
def format_hostings(breakdown, asn_names, max_show=3):
    items = sorted(
        breakdown.items(),
        key=lambda kv: kv[1]['count'],
        reverse=True,
    )
    parts = []
    for asn, d in items[:max_show]:
        name = asn_names.get(asn, '?')
        if len(name) > 22:
            name = name[:21] + '…'
        parts.append(f"{asn} {name} ({d['count']}п/{len(d['ips'])}IP)")
    rest = len(items) - max_show
    if rest > 0:
        parts.append(f"{DIM}+{rest} ещё{NC}")
    return "; ".join(parts)

def print_violators(per_email, grand_total, grand_hosting, asn_names,
                    min_hosting, filter_severity, hours):
    violators = []
    for email, d in per_email.items():
        sev = classify(d, min_hosting)
        if sev is None:
            continue
        if filter_severity != 'all' and sev != filter_severity.upper():
            continue
        violators.append((sev, email, d))

    violators.sort(key=lambda v: (SEVERITY_ORDER[v[0]], -v[2]['hosting_total']))

    print(f"\n{CYAN}{BOLD}═══ НАРУШИТЕЛИ — подключения с хостинговых ASN "
          f"(последние {hours}ч) ═══{NC}\n")

    if not violators:
        log(f"Нарушителей не обнаружено (порог: {min_hosting} хостинг-подкл)")
        if grand_hosting > 0:
            info(f"  но {grand_hosting} хостинговых подкл всё же было — "
                 f"снизь порог через --min-hosting если нужно увидеть")
        print()
        return

    by_sev = Counter(v[0] for v in violators)

    email_w = 32
    print(f"  {'Уровень':<7} {'Email':<{email_w}} {'Подкл':>6} {'IP':>4} "
          f"{'Хост%':>6}  Хостинги (топ-3)")
    print("  " + "─" * 110)

    for sev, email, d in violators:
        clr = SEVERITY_COLOR[sev]
        em = (email[:email_w-1] + '…') if len(email) > email_w else email
        pct = (d['hosting_total'] * 100 / d['total']) if d['total'] else 0
        hosts = format_hostings(d['hosting_breakdown'], asn_names, max_show=3)
        sev_tag = f"[{sev:<4}]"
        print(f"  {clr}{sev_tag}{NC} {em:<{email_w}} "
              f"{d['total']:>6} {len(d['unique_ips']):>4} "
              f"{pct:>5.0f}%  {hosts}")

    print("  " + "─" * 110)
    sev_summary = ", ".join(
        f"{SEVERITY_COLOR[k]}{by_sev[k]} {k}{NC}"
        for k in ('HIGH', 'MED', 'LOW') if by_sev.get(k)
    )
    pct_global = (grand_hosting * 100 / grand_total) if grand_total else 0
    print(f"\n  Нарушителей: {BOLD}{len(violators)}{NC}  ({sev_summary})")
    print(f"  Хостинговых подкл: {grand_hosting} из {grand_total} "
          f"({pct_global:.1f}% общего трафика)")
    print()

    print(f"  {DIM}{RED}[HIGH]{NC}{DIM} ≥90% трафика с хостинга — точно цепочка VPN, на бан{NC}")
    print(f"  {DIM}{YELLOW}[MED ]{NC}{DIM} 30-89% с хостинга — преимущественно через VPS{NC}")
    print(f"  {DIM}{CYAN}[LOW ]{NC}{DIM} <30%, но >={min_hosting} хостинг-подкл — "
          f"проверить вручную{NC}")
    print()

